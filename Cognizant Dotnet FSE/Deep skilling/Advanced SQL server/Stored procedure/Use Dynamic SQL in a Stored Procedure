CREATE PROCEDURE sp_GetEmployeesDynamic
    @FilterColumn VARCHAR(50), 
    @FilterValue VARCHAR(100)  
AS
BEGIN
    DECLARE @DynamicSQL NVARCHAR(MAX);

    SET @DynamicSQL = N'SELECT EmployeeID, FirstName, LastName, DepartmentID, Salary, JoinDate 
                        FROM Employees 
                        WHERE ' + QUOTENAME(@FilterColumn) + N' = @Value';

    EXEC sp_executesql @DynamicSQL, N'@Value VARCHAR(100)', @Value = @FilterValue;
END;